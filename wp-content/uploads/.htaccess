# Impide ejecutar PHP (y similares) dentro de la carpeta de medios.
# Mitiga riesgo si se sube un archivo malicioso disfrazado de imagen.
# Compatible con Apache 2.2 y 2.4 (cPanel).

<IfModule mod_authz_core.c>
	<FilesMatch "(?i)\.(php|phtml|phar|php[0-9]*)$">
		Require all denied
	</FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
	<FilesMatch "(?i)\.(php|phtml|phar|php[0-9]*)$">
		Order deny,allow
		Deny from all
	</FilesMatch>
</IfModule>
